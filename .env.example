ADMIN_EMAIL=tech@ads-ai.in
ADMIN_PASSWORD=replace-with-a-long-random-password
DEALS_DATA_DIR=/app/data
CRON_SECRET=replace-with-a-long-random-secret
AMAZON_CREATORS_CREDENTIAL_ID=
AMAZON_CREATORS_CREDENTIAL_SECRET=
AMAZON_CREATORS_CREDENTIAL_VERSION=
AMAZON_PARTNER_TAG=adsaideals-21
AMAZON_MARKETPLACE=www.amazon.in

# Amazon Creators API — Phase 2
AMAZON_PARTNER_TAG=adsaideals-21
AMAZON_MARKETPLACE=www.amazon.in
AMAZON_CREATORS_API_BASE=https://creatorsapi.amazon/catalog/v1
AMAZON_CREATORS_TOKEN_URL=
AMAZON_CREATORS_CREDENTIAL_ID=
AMAZON_CREATORS_CREDENTIAL_SECRET=
AMAZON_CREATORS_CREDENTIAL_VERSION=2.2

# Imported deals stay in review unless publish=true is explicitly supplied.
AMAZON_DISCOVERY_KEYWORDS=headphones,smart watches,mobile accessories,kitchen appliances,home appliances
AMAZON_DISCOVERY_SEARCH_INDEX=All
AMAZON_DISCOVERY_MINIMUM_DISCOUNT=10
AMAZON_DISCOVERY_MINIMUM_RATING=3.5
